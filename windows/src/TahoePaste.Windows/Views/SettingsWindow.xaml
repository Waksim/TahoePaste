<Window x:Class="TahoePaste.Windows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TahoePaste Settings"
        Width="720"
        Height="780"
        MinWidth="680"
        MinHeight="680"
        WindowStartupLocation="Manual"
        Loaded="OnLoaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock x:Name="HeaderTitle"
                       FontFamily="{StaticResource TahoeFont}"
                       FontSize="28"
                       FontWeight="Bold" />
            <TextBlock x:Name="HeaderSubtitle"
                       FontFamily="{StaticResource TahoeFont}"
                       FontSize="13"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Margin="0,4,0,18" />

            <GroupBox x:Name="GeneralGroup" Margin="0,0,0,14">
                <StackPanel Margin="10">
                    <TextBlock x:Name="LanguageLabel" Margin="0,0,0,6" />
                    <ComboBox x:Name="LanguageCombo" SelectionChanged="OnLanguageChanged" />
                    <CheckBox x:Name="LaunchAtLoginCheck" Margin="0,12,0,0" Checked="OnLaunchAtLoginChanged" Unchecked="OnLaunchAtLoginChanged" />
                    <TextBlock x:Name="LaunchAtLoginHelp" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0" />
                    <Button x:Name="OpenStartupButton" HorizontalAlignment="Left" Margin="0,8,0,0" Click="OnOpenStartupClick" />
                    <CheckBox x:Name="ShowTrayIconCheck" Margin="0,12,0,0" Checked="OnShowTrayIconChanged" Unchecked="OnShowTrayIconChanged" />
                    <TextBlock x:Name="ShowTrayIconHelp" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0" />
                    <Separator Margin="0,12,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ShortcutLabel" />
                        <TextBlock Grid.Column="1" Text="Ctrl + Shift + C" FontFamily="Cascadia Mono, Consolas" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="HotkeyStatusLabel" />
                        <TextBlock x:Name="HotkeyStatusValue" Grid.Column="1" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox x:Name="ClipboardGroup" Margin="0,0,0,14">
                <StackPanel Margin="10">
                    <CheckBox x:Name="CaptureTextCheck" Checked="OnCaptureTextChanged" Unchecked="OnCaptureTextChanged" />
                    <CheckBox x:Name="CaptureImagesCheck" Margin="0,8,0,0" Checked="OnCaptureImagesChanged" Unchecked="OnCaptureImagesChanged" />
                    <CheckBox x:Name="PauseMonitoringCheck" Margin="0,8,0,0" Checked="OnPauseMonitoringChanged" Unchecked="OnPauseMonitoringChanged" />
                    <Separator Margin="0,12,0,12" />
                    <CheckBox x:Name="UnlimitedHistoryCheck" Checked="OnUnlimitedHistoryChanged" Unchecked="OnUnlimitedHistoryChanged" />
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock x:Name="MaximumHistoryItemsLabel" DockPanel.Dock="Left" VerticalAlignment="Center" />
                        <TextBlock x:Name="MaximumHistoryItemsValue" DockPanel.Dock="Right" VerticalAlignment="Center" />
                    </DockPanel>
                    <Slider x:Name="MaximumHistoryItemsSlider" Minimum="10" Maximum="1000" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="OnMaximumHistoryItemsChanged" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CurrentStatusLabel" />
                        <TextBlock x:Name="CurrentStatusValue" Grid.Column="1" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SavedItemsLabel" />
                        <TextBlock x:Name="SavedItemsValue" Grid.Column="1" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                    </Grid>
                    <Button x:Name="ClearHistoryButton" HorizontalAlignment="Left" Margin="0,12,0,0" Click="OnClearHistoryClick" />
                </StackPanel>
            </GroupBox>

            <GroupBox x:Name="PasteGroup" Margin="0,0,0,14">
                <StackPanel Margin="10">
                    <CheckBox x:Name="AutoPasteCheck" Checked="OnAutoPasteChanged" Unchecked="OnAutoPasteChanged" />
                    <CheckBox x:Name="ReactivateCheck" Margin="0,8,0,0" Checked="OnReactivateChanged" Unchecked="OnReactivateChanged" />
                    <DockPanel Margin="0,12,0,0">
                        <TextBlock x:Name="PasteDelayLabel" DockPanel.Dock="Left" VerticalAlignment="Center" />
                        <TextBlock x:Name="PasteDelayValue" DockPanel.Dock="Right" VerticalAlignment="Center" />
                    </DockPanel>
                    <Slider x:Name="PasteDelaySlider" Minimum="0.05" Maximum="0.30" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="OnPasteDelayChanged" />
                </StackPanel>
            </GroupBox>

            <GroupBox x:Name="AppearanceGroup" Margin="0,0,0,14">
                <StackPanel Margin="10">
                    <TextBlock x:Name="ThemeModeLabel" Margin="0,0,0,6" />
                    <ComboBox x:Name="ThemeModeCombo" SelectionChanged="OnThemeModeChanged" />
                    <TextBlock x:Name="ThemeModeHelp" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ActiveThemeLabel" />
                        <TextBlock x:Name="ActiveThemeValue" Grid.Column="1" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DayThemeStartsLabel" VerticalAlignment="Center" />
                        <TextBox x:Name="DayThemeStartText" Grid.Column="1" LostFocus="OnThemeTimeLostFocus" KeyDown="OnThemeTimeKeyDown" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="NightThemeStartsLabel" VerticalAlignment="Center" />
                        <TextBox x:Name="NightThemeStartText" Grid.Column="1" LostFocus="OnThemeTimeLostFocus" KeyDown="OnThemeTimeKeyDown" />
                    </Grid>
                    <TextBlock x:Name="ThemeScheduleHelp" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,8" />
                    <TextBlock x:Name="CardSizeLabel" Margin="0,8,0,6" />
                    <ComboBox x:Name="CardSizeCombo" SelectionChanged="OnCardSizeChanged" />
                    <CheckBox x:Name="AutoLayoutCheck" Margin="0,12,0,0" Checked="OnAutoLayoutChanged" Unchecked="OnAutoLayoutChanged" />
                    <TextBlock x:Name="AutoLayoutHelp" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,4,0,0" />
                    <StackPanel x:Name="LayoutSlidersPanel" Visibility="Collapsed" />
                    <CheckBox x:Name="ShowTimestampsCheck" Margin="0,12,0,0" Checked="OnShowTimestampsChanged" Unchecked="OnShowTimestampsChanged" />
                    <CheckBox x:Name="ShowMetadataCheck" Margin="0,8,0,0" Checked="OnShowMetadataChanged" Unchecked="OnShowMetadataChanged" />
                    <TextBlock x:Name="CardAppearanceLabel"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,14,0,0"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CornerRadiusLabel" VerticalAlignment="Center" />
                        <TextBlock x:Name="CornerRadiusValue"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                    </Grid>
                    <Slider x:Name="CornerRadiusSlider" Minimum="0" Maximum="28" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnCornerRadiusChanged" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TextCardCornerRadiusLabel" VerticalAlignment="Center" />
                        <TextBlock x:Name="TextCardCornerRadiusValue"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                    </Grid>
                    <Slider x:Name="TextCardCornerRadiusSlider" Minimum="0" Maximum="28" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnTextCardCornerRadiusChanged" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ImageCardCornerRadiusLabel" VerticalAlignment="Center" />
                        <TextBlock x:Name="ImageCardCornerRadiusValue"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                    </Grid>
                    <Slider x:Name="ImageCardCornerRadiusSlider" Minimum="0" Maximum="28" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnImageCardCornerRadiusChanged" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TextCardShadowLabel" VerticalAlignment="Center" />
                        <TextBlock x:Name="TextCardShadowValue"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                    </Grid>
                    <Slider x:Name="TextCardShadowSlider" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="OnTextCardShadowChanged" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ImageCardShadowLabel" VerticalAlignment="Center" />
                        <TextBlock x:Name="ImageCardShadowValue"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right" />
                    </Grid>
                    <Slider x:Name="ImageCardShadowSlider" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="OnImageCardShadowChanged" />
                </StackPanel>
            </GroupBox>

            <GroupBox x:Name="StorageGroup" Margin="0,0,0,14">
                <StackPanel Margin="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="InputAutomationLabel" />
                        <TextBlock x:Name="InputAutomationValue" Grid.Column="1" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="StorageUsedLabel" />
                        <TextBlock x:Name="StorageUsedValue" Grid.Column="1" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                    </Grid>
                    <TextBlock x:Name="StoragePathLabel" Margin="0,8,0,4" />
                    <TextBlock x:Name="StoragePathValue" FontFamily="Cascadia Mono, Consolas" FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                    <WrapPanel Margin="0,12,0,0">
                        <Button x:Name="TestInputButton" Margin="0,0,8,8" Click="OnTestInputClick" />
                        <Button x:Name="OpenPrivacyButton" Margin="0,0,8,8" Click="OnOpenPrivacyClick" />
                        <Button x:Name="RevealStorageButton" Margin="0,0,8,8" Click="OnRevealStorageClick" />
                        <Button x:Name="DeleteAllButton" Margin="0,0,8,8" Click="OnClearHistoryClick" />
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <TextBlock x:Name="StatusFooter"
                       FontSize="12"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Window>
