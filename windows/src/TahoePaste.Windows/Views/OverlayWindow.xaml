<Window x:Class="TahoePaste.Windows.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TahoePaste"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Deactivated="OnDeactivated"
        PreviewKeyDown="OnPreviewKeyDown"
        TextInput="OnTextInput">
    <Grid x:Name="RootGrid">
        <Border x:Name="OverlayBorder"
                BorderThickness="0,1,0,0"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid x:Name="TopBar" Grid.Row="0" Height="36">
                    <Border x:Name="SearchBubble"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="10"
                            BorderThickness="1"
                            Visibility="Collapsed">
                        <DockPanel LastChildFill="True" Margin="14,0,10,0">
                            <Button x:Name="ClearSearchButton"
                                    DockPanel.Dock="Right"
                                    Width="22"
                                    Height="22"
                                    Content="x"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Click="OnClearSearchClick" />
                            <TextBlock x:Name="SearchText"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource TahoeFont}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </Border>

                    <StackPanel x:Name="ToolbarPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                        <Button x:Name="SettingsButton"
                                Content="⚙"
                                BorderThickness="0"
                                Background="Transparent"
                                Click="OnSettingsClick" />
                        <Button x:Name="SearchButton"
                                Content="⌕"
                                BorderThickness="0"
                                Background="Transparent"
                                Click="OnSearchClick" />
                        <Button x:Name="ReturnButton"
                                Content="↺"
                                BorderThickness="0"
                                Background="Transparent"
                                Visibility="Collapsed"
                                Click="OnReturnClick" />
                        <Button x:Name="ScrollStartButton"
                                Content="←"
                                BorderThickness="0"
                                Background="Transparent"
                                Click="OnScrollStartClick" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <StackPanel x:Name="EmptyPanel"
                                Margin="32,0,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Visibility="Collapsed">
                        <TextBlock x:Name="EmptyTitle"
                                   FontFamily="{StaticResource TahoeFont}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="EmptySubtitle"
                                   FontFamily="{StaticResource TahoeFont}"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Width="420"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <ScrollViewer x:Name="CardsScroll"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled"
                                  PanningMode="HorizontalOnly"
                                  CanContentScroll="False"
                                  PreviewMouseWheel="OnCardsMouseWheel">
                        <StackPanel x:Name="CardsPanel"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Bottom"
                                    Margin="16,0,16,16" />
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
